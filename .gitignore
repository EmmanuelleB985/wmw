# ==========================================================================
# WMW-TRACEBANK .gitignore
#
# Policy: keep the *released, deterministic* seed artifacts under version
# control (they are cited in the paper by SHA-256 and regenerate exactly
# from seed 2026), but ignore everything that is produced by running the
# pipeline: model outputs, verifier results, downloaded external datasets,
# rendered images, training checkpoints, and LaTeX/figure outputs.
#
# To regenerate the ignored seed-derived data:
#     python scripts/generate_tracebank.py        # data/*_seed.jsonl, splits, stats
#     python scripts/download_datasets.py          # data/eval/, data/eval_data/
#     python scripts/run_evaluation.py ...         # data/results/
# ==========================================================================

# ---------------------------------------------------------------------------
# Generated evaluation & experiment outputs
# ---------------------------------------------------------------------------
# Model generations, verifier labels, stress tests, reranking, LaTeX tables.
# All produced by scripts/run_evaluation.py and scripts/analysis/*.
data/results/
data/experiments/

# Per-model raw traces / checkpoints / temp sweeps anywhere they land
*_raw_traces.jsonl
*_per_example.jsonl
*_rerank_sweep.jsonl
*.jsonl.tmp

# ---------------------------------------------------------------------------
# Downloaded / converted external datasets (ScienceQA, CLEVRER, MathVista)
# ---------------------------------------------------------------------------
# Re-created by scripts/download_datasets.py. These retain their own upstream
# licenses and must not be redistributed in the repo.
data/eval/
data/eval_data/

# ---------------------------------------------------------------------------
# DPO training data and HuggingFace release bundle
# ---------------------------------------------------------------------------
# Built from the seed preference pairs by scripts/reproduce/prepare_dpo_data.py
# and scripts/bundle_model_outputs.py respectively.
data/dpo/
data/hf_release/

# ---------------------------------------------------------------------------
# Model checkpoints / LoRA adapters
# ---------------------------------------------------------------------------
checkpoints/
*.safetensors
*.bin
*.pt
adapter_model.*
adapter_config.json

# ---------------------------------------------------------------------------
# Rendered diagrams (regenerated by scripts/generate_eval_diagrams.py)
# ---------------------------------------------------------------------------
*.png
*.jpg
*.jpeg
*.svg
# ...but keep any figures intentionally committed for docs:
!docs/**/*.png
!docs/**/*.svg

# ---------------------------------------------------------------------------
# KEEP these released, deterministic seed artifacts (negated below)
# ---------------------------------------------------------------------------
# They live directly under data/ and are NOT matched by the directory rules
# above, but are listed explicitly here as documentation of intent.
#   data/trace_examples_seed.jsonl
#   data/preference_pairs_seed.jsonl
#   data/splits.json
#   data/generation_stats.json
#   data/audit_sample.jsonl

# ==========================================================================
# Standard Python
# ==========================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Test / coverage / type-check caches
.pytest_cache/
.cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
.hypothesis/

# Jupyter
.ipynb_checkpoints/

# ==========================================================================
# Editors / OS
# ==========================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ==========================================================================
# Secrets — never commit API keys
# ==========================================================================
.env.local
*.key
secrets.json
